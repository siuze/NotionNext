+  height: 14px !important;
+  display: inline-block;
+  vertical-align: middle;
+  margin-top: -2px;
+  margin-right: 4px;
+}
+
+
+
+
+
+
+
+/* 容器修复 */
+.notion-github-link-wrapper {
+  position: relative !important;
+  overflow: visible !important; /* 关键：如果不设为 visible，卡片会被挡在里面 */
+  display: inline-flex !important;
+  align-items: center;
+  text-decoration: none !important;
+  z-index: 1 !important;
+}
+
+/* 解决图标太大的问题 */
+.notion-github-icon-box {
+  display: inline-flex;
+  align-items: center;
+  margin-right: 4px;
+}
+.notion-github-icon-box svg {
+  width: 14px !important;
+  height: 14px !important;
+  flex-shrink: 0;
+}
+
+/* 哈希值颜色 */
+.notion-github-inline-hash {
+  color: #37352fa6 !important;
+  font-family: monospace;
+  font-size: 0.9em;
+}
+
+/* 弹出标签彻底重构 */
+.notion-github-popup-card {
+  position: absolute !important;
+  /* 位置在上方 */
+  bottom: calc(100% + 10px) !important;
+  margin-bottom: 10px !important;
+  left: 0 !important;
+  
+  /* 基础视觉样式 */
+  display: flex !important;
+  min-width: 320px !important;
+  max-width: 550px !important; /* 与实际正文 Block 差不多宽 */
+  width: max-content !important;
+  padding: 12px 16px !important;
+  background: #ffffff !important;
+  border: 1px solid rgba(0, 0, 0, 0.09) !important;
+  border-radius: 8px !important;
+  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.04) !important;
+  color: rgb(55, 53, 47) !important;
+  z-index: 10000 !important;
+  pointer-events: none !important; /* 悬停前彻底无感 */
+  white-space: normal !important;
+  flex-direction: column !important; /* 强制垂直排列子项 */
+  gap: 2px !important; /* 行与行之间的间距 */
+  font-family: inherit !important; /* 强制继承主站字体 */
+  /* 核心：动效 */
+  opacity: 0 !important;
+  visibility: hidden !important;
+  transform: scale(0.95) translateY(5px) !important;
+  transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s !important;
+}
+
+/* 只有当 Wrapper 被 Hover 时，Card 才出来 */
+.notion-github-link-wrapper:hover .notion-github-popup-card {
+  opacity: 1 !important;
+  visibility: visible !important;
+  transform: scale(1) translateY(0) !important;
+  z-index: 9999 !important; /* 悬停时瞬间提升到最高 */
+}
+.notion-github-popup-card > div:last-child {
+  display: flex !important;
+  flex-direction: column !important;
+  gap: 8px !important; /* 如果有 Author 和 Owner 两行，控制它们之间的间距 */
+}
+/* 卡片内部样式排版 */
+.notion-preview-card-title {
+  font-size: 14px;
+  font-weight: 600;
+  margin-bottom: 8px !important;
+  line-height: 1.4;
+  color: black;
+  word-break: break-word !important;
+}
+.notion-external-subtitle-item {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  font-size: 12px;
+  color: rgba(55, 53, 47, 0.65);
+}
